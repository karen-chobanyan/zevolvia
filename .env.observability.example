# Grafana credentials (REQUIRED - change from defaults)
GRAFANA_ADMIN_USER=zevolvia-admin
GRAFANA_ADMIN_PASSWORD=change-me-to-a-strong-password

# Grafana URL settings (set these when behind Nginx subpath)
# Example:
# GF_SERVER_ROOT_URL=https://your-domain.com/api/live
# GF_SERVER_SERVE_FROM_SUB_PATH=true
# GF_LIVE_ALLOWED_ORIGINS=https://your-domain.com https://www.your-domain.com
GF_SERVER_ROOT_URL=http://localhost:3030
GF_SERVER_SERVE_FROM_SUB_PATH=false
GF_LIVE_ALLOWED_ORIGINS=

# Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email alerts
ALERT_EMAIL_ADDRESSES=ops@example.com
GF_SMTP_ENABLED=true
GF_SMTP_HOST=smtp.yourprovider.com:587
GF_SMTP_USER=your-smtp-user
GF_SMTP_PASSWORD=your-smtp-password
GF_SMTP_FROM_ADDRESS=grafana@example.com
GF_SMTP_FROM_NAME=Example Alerts
