# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=zevolvia

# Authentication
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=1d
WEB_ORIGIN=http://localhost:3000
SEED_EMAIL=owner@example.com
SEED_PASSWORD=ChangeMe123!
SEED_FIRST_NAME=Demo
SEED_LAST_NAME=Owner
SEED_ORG_NAME=Example Studio

# MinIO Configuration
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zevolvia-files

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small

# Billing Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PRICE_YEARLY=price_your_yearly_price_id
STRIPE_PRICE_MONTHLY=price_your_monthly_price_id
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard/billing?success=1&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/dashboard/billing?canceled=1
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/dashboard/billing

# Email Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM='"Example App" <noreply@example.com>'

# Time zone
DEFAULT_TIME_ZONE=UTC

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_URL=http://localhost:3001/api/sms/twilio
TWILIO_STATUS_CALLBACK_URL=http://localhost:3001/api/sms/twilio/status
TWILIO_VALIDATE_SIGNATURE=true

# Chunking Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=150
