# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=zevolvia
DB_CONNECT_TIMEOUT_MS=5000

# Authentication
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=1d
WEB_ORIGIN=http://localhost:3000
SEED_EMAIL=owner@example.com
SEED_PASSWORD=ChangeMe123!
SEED_FIRST_NAME=Demo
SEED_LAST_NAME=Owner
SEED_ORG_NAME=Example Studio

# MinIO Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=zevolvia-files

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
EMBEDDING_MODEL=text-embedding-3-small

# Twilio Configuration (optional development fallback; tenants configure their own in org settings)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WEBHOOK_URL=
TWILIO_STATUS_CALLBACK_URL=
TWILIO_VALIDATE_SIGNATURE=true

# Telegram booking webhook (optional development fallback; tenants configure their own in org settings)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Chunking Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
