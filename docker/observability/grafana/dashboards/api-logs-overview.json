      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "avg_over_time({service=\"api\", env=~\"$env\"} | json | unwrap duration [$__interval]) by ()",
          "legendFormat": "avg",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "quantile_over_time(0.95, {service=\"api\", env=~\"$env\"} | json | unwrap duration [$__interval]) by ()",
          "legendFormat": "p95",
          "queryType": "range",
          "refId": "B"
        }
      ],
      "title": "Request Latency (from logs)",
      "type": "timeseries"
    },
