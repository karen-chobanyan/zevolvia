          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "{service=\"api\", env=~\"$env\"} |= \"$orgId\" |= \"$requestId\" | json",
          "queryType": "range",
          "refId": "A"
        }
      ],
